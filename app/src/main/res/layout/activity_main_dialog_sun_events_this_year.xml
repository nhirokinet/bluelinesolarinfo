<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12sp"
    tools:context=".activities.MainActivity">
    <TextView
        android:id="@+id/main_activity_dialog_sun_this_year_title_year"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        />
    <TableLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="16sp"
        >
        <TableRow>
            <TextView
                android:id="@+id/main_activity_dialog_sun_this_year_event_0_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                />
            <TextView
                android:id="@+id/main_activity_dialog_sun_this_year_equinox_0_date"
                android:textSize="20sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8sp"
                android:layout_gravity="center_vertical"
                />
        </TableRow>
        <TableRow>
            <TextView
                android:id="@+id/main_activity_dialog_sun_this_year_event_90_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                />
            <TextView
                android:id="@+id/main_activity_dialog_sun_this_year_equinox_90_date"
                android:textSize="20sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8sp"
                android:layout_gravity="center_vertical"
                />
        </TableRow>
        <TableRow>
            <TextView
                android:id="@+id/main_activity_dialog_sun_this_year_event_180_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                />
            <TextView
                android:id="@+id/main_activity_dialog_sun_this_year_equinox_180_date"
                android:textSize="20sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8sp"
                android:layout_gravity="center_vertical"
                />
        </TableRow>
        <TableRow>
            <TextView
                android:id="@+id/main_activity_dialog_sun_this_year_event_270_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                />
            <TextView
                android:id="@+id/main_activity_dialog_sun_this_year_equinox_270_date"
                android:textSize="20sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8sp"
                android:layout_gravity="center_vertical"
                />
        </TableRow>
    </TableLayout>
    <TextView
        android:id="@+id/main_activity_dialog_sun_this_year_timezone"
        android:paddingTop="20sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        />
</LinearLayout>
